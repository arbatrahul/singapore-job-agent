# Copy to .env and fill in. .env is gitignored.

# Anthropic API for Claude Haiku ranker
ANTHROPIC_API_KEY=sk-ant-...

# Resend (https://resend.com) — HTTP email API. GitHub-hosted runners block
# Gmail SMTP, so we use Resend's HTTPS endpoint instead.
#   Free tier: 3,000 emails/mo, 100/day.
#   Default sender `onboarding@resend.dev` works without domain verification
#   but only sends to the email address used to sign up.
RESEND_API_KEY=re_...
DIGEST_FROM=SG Jobs Digest <onboarding@resend.dev>
DIGEST_TO=you@example.com

# Optional: comma-separated LinkedIn saved-search RSS URLs
LINKEDIN_RSS_URLS=

# Optional: comma-separated extra RSS feeds. Format:
#   "label1|https://...,label2|https://..."
EXTRA_RSS_URLS=

# DRY_RUN=1 writes email to out/digest.html instead of sending
DRY_RUN=0
