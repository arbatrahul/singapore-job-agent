# Copy to .env and fill in. .env is gitignored.

# Anthropic API for Claude Haiku ranker
ANTHROPIC_API_KEY=sk-ant-...

# SMTP (Gmail app password recommended — https://myaccount.google.com/apppasswords)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@example.com
SMTP_PASSWORD=xxxx-xxxx-xxxx-xxxx
DIGEST_FROM=you@example.com
DIGEST_TO=you@example.com

# Optional: comma-separated LinkedIn saved-search RSS URLs (from linkedin.com/jobs/search via saved search)
LINKEDIN_RSS_URLS=

# DRY_RUN=1 writes email to out/digest.html instead of sending
DRY_RUN=0
