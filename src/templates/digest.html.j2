<!doctype html>
<html>
<head>
<meta charset="utf-8">
<title>SG Jobs Digest — {{ date }}</title>
</head>
<body style="font-family: -apple-system, Segoe UI, Helvetica, Arial, sans-serif; color: #111; max-width: 720px; margin: 0 auto; padding: 24px;">
  <h1 style="margin: 0 0 4px 0; font-size: 22px;">Singapore Tech Roles — {{ date }}</h1>
  <p style="color: #666; margin: 0 0 24px 0; font-size: 14px;">
    Top {{ ranked|length }} of {{ total_candidates }} candidates pulled from {{ source_count }} source(s). Floor: S${{ salary_floor }}/mo.
  </p>

  {% for r in ranked %}
  <div style="border: 1px solid #e4e4e7; border-radius: 10px; padding: 16px; margin-bottom: 14px;">
    <div style="display: flex; justify-content: space-between; align-items: baseline;">
      <div>
        <a href="{{ r.job.url }}" style="font-weight: 600; font-size: 16px; color: #0a66c2; text-decoration: none;">{{ r.job.title }}</a>
        <div style="color: #333; font-size: 14px;">{{ r.job.company }}{% if r.job.employment_type %} · {{ r.job.employment_type }}{% endif %}</div>
      </div>
      <div style="font-weight: 700; color: {% if r.score >= 85 %}#15803d{% elif r.score >= 70 %}#0a66c2{% else %}#6b7280{% endif %}; font-size: 18px;">
        {{ r.score }}
      </div>
    </div>
    <p style="margin: 10px 0 6px 0; font-size: 14px; color: #111;">{{ r.why_fits }}</p>
    <div style="font-size: 12px; color: #6b7280;">
      {% if r.job.salary_min_sgd_monthly %}S${{ "{:,}".format(r.job.salary_min_sgd_monthly) }}{% if r.job.salary_max_sgd_monthly %}–S${{ "{:,}".format(r.job.salary_max_sgd_monthly) }}{% endif %}/mo · {% endif %}
      {{ r.job.source }}
      {% if r.job.posted_at %} · posted {{ r.job.posted_at.strftime('%Y-%m-%d') }}{% endif %}
      {% if r.flags %} · <em>{{ r.flags|join(', ') }}</em>{% endif %}
    </div>
  </div>
  {% endfor %}

  {% if ranked|length == 0 %}
  <p style="color: #6b7280;">No roles cleared filtering today. This may indicate a source outage — check the workflow logs.</p>
  {% endif %}

  <hr style="border: none; border-top: 1px solid #e4e4e7; margin: 32px 0 12px 0;">
  <p style="color: #9ca3af; font-size: 12px;">
    Generated by sg-jobs-agent · scored with Claude Haiku · filters at the top.
  </p>
</body>
</html>
